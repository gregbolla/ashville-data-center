---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Ashville Data Center & Gas Power Plant</h1>
				<p class="subtitle">
					A proposed 800 MW natural gas power plant to support a new data center in Ashville, Ohio.
					The data center has been approved by Ashville Town Council. The power plant requires
					approval from the <strong>Ohio Power Siting Board (OPSB)</strong>.
				</p>
			</section>

			<section class="status">
				<h2>Current Status</h2>
				<div class="status-grid">
					<div class="status-card approved">
						<span class="label">Approved</span>
						<h3>Data Center</h3>
						<p>Approved by Ashville Town Council</p>
					</div>
					<div class="status-card pending">
						<span class="label">Pending</span>
						<h3>800 MW Gas Power Plant</h3>
						<p>Application before the Ohio Power Siting Board (OPSB)</p>
					</div>
				</div>
			</section>

			<section class="updates">
				<h2>Latest Updates</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<h3>{post.data.title}</h3>
								<time><FormattedDate date={post.data.pubDate} /></time>
								{post.data.description && <p>{post.data.description}</p>}
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2em 1em;
	}
	.hero {
		margin-bottom: 3em;
		border-bottom: 1px solid #eee;
		padding-bottom: 2em;
	}
	.hero h1 {
		font-size: 2em;
		margin-bottom: 0.5em;
	}
	.subtitle {
		font-size: 1.1em;
		line-height: 1.6;
		color: #444;
	}
	.status {
		margin-bottom: 3em;
	}
	.status-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1em;
		margin-top: 1em;
	}
	.status-card {
		padding: 1.5em;
		border-radius: 6px;
		border: 1px solid #ddd;
	}
	.status-card .label {
		font-size: 0.75em;
		font-weight: bold;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.status-card.approved .label { color: #2a7d4f; }
	.status-card.pending .label { color: #b45309; }
	.status-card h3 {
		margin: 0.4em 0 0.3em;
		font-size: 1.1em;
	}
	.status-card p {
		margin: 0;
		color: #555;
		font-size: 0.95em;
	}
	.updates h2 {
		margin-bottom: 1em;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li {
		border-bottom: 1px solid #eee;
	}
	.post-list li:last-child {
		border-bottom: none;
	}
	.post-list a {
		display: block;
		padding: 1.25em 0;
		text-decoration: none;
		color: inherit;
	}
	.post-list a:hover h3 {
		text-decoration: underline;
	}
	.post-list h3 {
		margin: 0 0 0.2em;
		font-size: 1.1em;
	}
	.post-list time {
		font-size: 0.85em;
		color: #888;
	}
	.post-list p {
		margin: 0.4em 0 0;
		color: #555;
		font-size: 0.95em;
	}
	@media (max-width: 600px) {
		.status-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
