---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Ashville Data Center & Gas Power Plant</h1>
				<p class="subtitle">
					A global data center developer offered Ashville, Ohio $102 million to approve a massive facility on 195 acres, declaring it an emergency so residents wouldn't have a chance to organize a referendum that would have allowed the public to vote on it. An application for a <strong>800 MW natural gas plant</strong> is currently being considered by the Ohio Power Siting Board, with a decision expected by October 2026.
				</p>
				<p class="subtitle">
					This site is dedicated to understanding the dynamics involved with constructing and operating the data center and associated gas plant, as well as the various regulatory, scientific, and bureaucratic layers involved.
				</p>
			</section>

			<section class="updates">
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<h3>{post.data.title}</h3>
							</a>
							<time><FormattedDate date={post.data.pubDate} /></time>
							{post.data.description && <p>{post.data.description}</p>}
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		width: 100%;
		box-sizing: border-box;
		margin: 0 auto;
		padding: 2em 1em;
	}
	.hero {
		margin-bottom: 1.5em;
		border-bottom: 1px solid #eee;
		padding-bottom: 1.25em;
	}
	.hero h1 {
		font-size: 2em;
		margin-bottom: 0.5em;
	}
	.subtitle {
		font-size: 1.1em;
		line-height: 1.6;
		color: #444;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li {
		border-bottom: 1px solid #eee;
	}
	.post-list li:last-child {
		border-bottom: none;
	}
	.post-list a {
		display: block;
		padding: 1em 0;
		text-decoration: none;
		color: inherit;
	}
	.post-list a:hover h3 {
		text-decoration: underline;
	}
	.post-list h3 {
		margin: 0 0 0.25em;
		font-family: var(--font-bicubik), sans-serif;
		font-size: 1.4em;
		color: var(--green-light);
		line-height: 1.2;
	}
	.post-list time {
		font-size: 0.8em;
		color: #888;
	}
	.post-list p {
		margin: 0.5em 0 0;
		color: #555;
		font-size: 0.95em;
		line-height: 1.5;
	}
	@media (max-width: 720px) {
		main {
			padding: 1.5em 1em;
		}
		.hero {
			margin-bottom: 1em;
			padding-bottom: 1em;
		}
		.hero h1 {
			font-size: 1.6em;
		}
		.subtitle {
			font-size: 1em;
		}
		.post-list h3 {
			font-size: 1.15em;
		}
	}
</style>
